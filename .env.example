# ── AWS Credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-video-bucket-name

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./streamvault.db

# PostgreSQL (uncomment and fill in to switch):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/streamvault

# ── App Settings ──────────────────────────────────────────────────────────────
APP_NAME=StreamVault
PRESIGNED_URL_EXPIRY=3600        # seconds — how long video links stay valid
MAX_UPLOAD_SIZE_MB=2048          # 2 GB hard cap
